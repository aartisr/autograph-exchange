AUTH_SECRET=replace-with-a-long-random-secret
# Optional: override local file storage location.
# AUTOGRAPH_DATA_DIR=/absolute/path/to/data-dir
# AUTOGRAPH_DATA_FILE=/absolute/path/to/autograph-exchange.json

# Persistence driver:
# file | supabase
AUTOGRAPH_PERSISTENCE_DRIVER=file

# Convenience toggle. If true, Supabase is used even if AUTOGRAPH_PERSISTENCE_DRIVER is unset.
# AUTOGRAPH_ENABLE_SUPABASE=true

# Supabase persistence configuration.
# AUTOGRAPH_SUPABASE_URL=https://your-project.supabase.co
# AUTOGRAPH_SUPABASE_KEY=your-supabase-service-role-or-anon-key
# AUTOGRAPH_SUPABASE_SCHEMA=public
# AUTOGRAPH_SUPABASE_PROFILES_TABLE=autograph_profiles
# AUTOGRAPH_SUPABASE_REQUESTS_TABLE=autograph_requests
